{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Tailor Platform App Shell",
  "theme": "palm",
  "colors": {
    "primary": "#2563eb",
    "light": "#3b82f6",
    "dark": "#1e40af"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/tailor-platform/app-shell"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/tailor-platform/app-shell"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
