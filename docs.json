            "pages": [
              "concepts/modules-and-resources",
              "concepts/routing-navigation",
              "concepts/authentication",
              "concepts/styling-theming",
              "concepts/file-based-routing"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/building-your-first-app",
              "guides/custom-layouts",
              "guides/guards-permissions",
              "guides/internationalization"
            ]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Core Components",
            "pages": [
              "components/app-shell",
              "components/sidebar-layout",
              "components/command-palette"
            ]
          },
          {
            "group": "UI Components",
            "pages": [
