              "api/use-theme",
              "api/use-toast",
              "api/use-page-meta"
            ]
          },
          {
            "group": "Guards",
            "pages": [
              "api/guards/overview",
              "api/guards/pass",
              "api/guards/hidden",
              "api/guards/redirect-to"
